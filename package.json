{
  "version": "7.3.1",
  "webpackConfigJaid": "cli",
  "author": "Jaid <jaid.jsx@gmail.com> (https://github.com/Jaid)",
  "description": "Overwrites the readme based on info fetched from package.json and source code.",
  "dependencies": {
    "@absolunet/fsp": "^1.7.0",
    "array-to-object-keys": "^1.3.7",
    "build-url": "^6.0.1",
    "camelcase": "^9.0.0",
    "chalk": "^5.6.2",
    "debug": "^4.4.3",
    "ensure-array": "^1.0.0",
    "ensure-object": "^1.0.1",
    "filesize": "^11.0.17",
    "git-url-parse": "^16.1.0",
    "globby": "^16.2.0",
    "handlebars": "^4.7.9",
    "has-content": "^1.1.1",
    "just-handlebars-helpers": "^1.0.19",
    "lodash-es": "^4.18.1",
    "normalize-package-data": "^8.0.0",
    "pascal-case": "^4.0.0",
    "prevent-end": "^1.0.6",
    "read-file-json": "^1.1.0",
    "read-file-string": "^1.1.2",
    "read-file-yaml": "^2.0.0",
    "sort-object": "^3.0.3",
    "url-parse": "^1.5.10",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "browserslist-config-jaid-node": "^3.0.0",
    "bun-types": "^1.3.14",
    "coffee": "^5.5.1",
    "eslint": "^10.3.0",
    "eslint-config-jaid": "^26.0.0",
    "tsconfig-jaid-bun": "^15.2.0",
    "typescript": "^6.0.3",
    "webpack-config-jaid": "^17.4.2"
  },
  "scripts": {
    "clean": "rimraf dist/",
    "babel:prod": "rimraf dist/transpiled/production && NODE_ENV=production babel --out-dir dist/transpiled/production --source-maps true src",
    "babel:dev": "rimraf dist/transpiled/development && NODE_ENV=development babel --out-dir dist/transpiled/development src",
    "babel:test": "rimraf dist/transpiled/test && NODE_ENV=test babel --out-dir dist/transpiled/test src",
    "build:prod": "NODE_ENV=production webpack",
    "build:dev": "NODE_ENV=development webpack",
    "test": "npm run build:prod && NODE_ENV=production MAIN=dist/package/production/cli.js jest --runInBand",
    "test:coverage": "npm run test:dev -- --coverage --json --outputFile=dist/jest/stats.json",
    "test:dev": "npm run build:dev && NODE_ENV=test MAIN=dist/package/development/cli.js jest --runInBand",
    "test:debug": "DEBUG=\"$(basename $PWD),$(basename $PWD):*\" NODE_ENV=test node --inspect=9229 node_modules/jest/bin/jest.js --runInBand",
    "prepareActionJest": "npm run build:prod"
  },
  "funding": "https://github.com/sponsors/Jaid",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaid/tldw"
  },
  "name": "tldw",
  "homepage": "https://github.com/jaid/tldw",
  "keywords": [
    "documentation",
    "github",
    "jsx",
    "markdown",
    "react",
    "react-renderer",
    "readme",
    "readme-template"
  ],
  "type": "module",
  "license": "MIT"
}
