{
  "name": "tldw",
  "version": "7.3.1",
  "type": "module",
  "description": "Generate README files from package metadata and configurable fragments.",
  "keywords": [
    "bun",
    "cli",
    "documentation",
    "markdown",
    "readme",
    "readme-template"
  ],
  "author": "Jaid <jaid.jsx@gmail.com> (https://github.com/Jaid)",
  "homepage": "https://github.com/Jaid/tldw",
  "funding": "https://github.com/sponsors/jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:Jaid/tldw.git"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": "./src/cli.ts",
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test",
    "dev": "bun --watch src/cli.ts",
    "lint": "bun x eslint src test package.json eslint.config.ts",
    "start": "bun src/cli.ts",
    "test": "bun test --max-concurrency 1 ./test",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "camelcase": "^9.0.0",
    "chalk": "^5.6.2",
    "clerc": "^1.3.1",
    "filesize": "^11.0.17",
    "forward-slash-path": "^0.3.0",
    "fs-extra": "^11.3.5",
    "globby": "^16.2.0",
    "handlebars": "^4.7.9",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "eslint": "^10.3.0",
    "eslint-config-jaid": "^26.0.0",
    "jiti": "^2.6.1",
    "tsconfig-jaid-bun": "^15.2.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "src",
    "license.txt",
    "readme.md"
  ]
}