{
  "name": "tldw",
  "displayName": "tl;dw",
  "version": "7.3.1",
  "type": "module",
  "description": "Generate README files from package metadata and configurable fragments.",
  "keywords": [
    "bun",
    "cli",
    "documentation",
    "markdown",
    "readme",
    "readme-template"
  ],
  "author": "Jaid <jaid.jsx@gmail.com> (https://github.com/Jaid)",
  "homepage": "https://github.com/Jaid/tldw",
  "funding": "https://github.com/sponsors/jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:Jaid/tldw.git"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": "./src/cli.ts",
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test",
    "dev": "bun --watch src/cli.ts",
    "lint": "bun x eslint src test package.json eslint.config.ts",
    "start": "bun src/cli.ts",
    "test": "bun test --max-concurrency 1 ./test",
    "typecheck": "bun x tsc --noEmit"
  },
  "dependencies": {
    "camelcase": "^9.0.0",
    "chalk": "^5.6.2",
    "clerc": "^1.3.1",
    "filesize": "^11.0.17",
    "forward-slash-path": "^0.3.0",
    "fs-extra": "^11.3.5",
    "globby": "^16.2.0",
    "handlebars": "^4.7.9",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-jaid": "^26.0.0",
    "github-markdown-css": "^5.9.0",
    "jiti": "^2.7.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tsconfig-jaid-bun": "^15.2.0",
    "typescript": "^6.0.3",
    "unified": "^11.0.5"
  },
  "files": [
    "src",
    "license.txt",
    "readme.md"
  ]
}